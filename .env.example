# 复制为 .env 后按需修改：docker compose 会自动读取本目录下的 .env 用于变量替换
# cp .env.example .env

# ---------- Grok2API ----------
HOST_PORT=8000
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1

# 存储：local | redis | mysql | pgsql
SERVER_STORAGE_TYPE=local

# 非 local 时必填，例如 MySQL：
# SERVER_STORAGE_URL=mysql+aiomysql://user:password@host:3306/grok2api
# 密码中含 @ # : / ? 等字符时请 URL 编码
SERVER_STORAGE_URL=
